0468" name="_8"><labels context="LABEL"><text context="QUESTION" xml:lang="en-GB">I trust that companies will use my online data securely and respectfully</text></labels></category><category id="_10469" name="_9"><labels context="LABEL"><text context="QUESTION" xml:lang="en-GB">I feel that I’m talking to people online more than in person</text></labels></category><category id="_10470" name="_10"><labels context="LABEL"><text context="QUESTION" xml:lang="en-GB">I feel technology is greatly improving human life</text></labels></category><category id="_10471" name="_11"><labels context="LABEL"><text context="QUESTION" xml:lang="en-GB">I look to the internet to stay updated on the news and current affairs</text></labels></category></categories><class name="@class" global-name-space="-1"><types name="@types" global-name-space="-1"><deleted/></types><fields name="@fields" global-name-space="-1"><deleted/><variable id="_10453" name="QFlag3_scale" ref="10453"/></fields><pages name="@pages" global-name-space="-1"><deleted/></pages></class></loop><variable id="_10487" name="FLAG_1" ref="10487"/><variable id="_10492" name="FLAG_2" ref="10492"/><variable id="_10497" name="FLAG_3" ref="10497"/><variable id="_10502" name="FLAG_4" ref="10502"/><variable id="_10507" name="FLAG_5" ref="10507"/><variable id="_10512" name="FLAG_6" ref="10512"/><variable id="_10517" name="FLAG_7" ref="10517"/><variable id="_10522" name="FLAG_8" ref="10522"/><variable id="_10527" name="FlagFinal" ref="10527"/><variable id="_10532" name="project_type" ref="10532"/><variable id="_10535" name="country_lead" ref="10535"/><variable id="_10538" name="service_level" ref="10538"/><variable id="_10541" name="retest" ref="10541"/><variable id="_10546" name="retest_JBNumbers" ref="10546"/><variable id="_10549" name="prj_incidence" ref="10549"/><variable id="_10552" name="CN_tier_recode" ref="10552"/><variable id="_10558" name="CA_RegionRecode" ref="10558"/><variable id="_10563" name="CN_inc_recode" ref="10563"/><v