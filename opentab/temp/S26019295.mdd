ts own: the capital cost of producing food or non-food to meet the the household’s needs.&lt;br/&gt;- Provision of: providing food or non food to others on a regular basis every month.&lt;br/&gt;&lt;br/&gt;&lt;span class='including'&gt;Click here for more details &lt;/span&gt; &lt;br/&gt;&lt;br/&gt;&lt;span class='notIncluding'&gt;Click here for more details &lt;/span&gt;</text></labels><categories global-name-space="-1"><deleted/><category id="_3197" name="_1"><labels context="LABEL"><text context="QUESTION" xml:lang="id-ID">Rp. 750.000 atau kurang</text><text context="QUESTION" xml:lang="en-US">Rp. 750.000 or less</text><text context="QUESTION" xml:lang="en-GB">Rp. 750.000 or less</text></labels><properties><property name="Value" value="1" type="8" context="Analysis"/></properties></category><category id="_3199" name="_2"><labels context="LABEL"><text context="QUESTION" xml:lang="id-ID">Rp. 750.001 - Rp. 900.000</text><text context="QUESTION" xml:lang="en-US">Rp. 750.001 - Rp. 900.000</text><text context="QUESTION" xml:lang="en-GB">Rp. 750.001 - Rp. 900.000</text></labels><properties><property name="Value" value="2" type="8" context="Analysis"/></properties></category><category id="_3200" name="_3"><labels context="LABEL"><text context="QUESTION" xml:lang="id-ID">Rp. 900.001 - Rp. 1.250.000</text><text context="QUESTION" xml:lang="en-US">Rp. 900.001 - Rp. 1.250.000</text><text context="QUESTION" xml:lang="en-GB">Rp. 900.001 - Rp. 1.250.000</text></labels><properties><property name="Value" value="3" type="8" context="Analysis"/></properties></category><category id="_3201" name="_4"><labels context="LABEL"><text context="QUESTION" xml:lang="id-ID">Rp. 1.250.001 - Rp.1.750.000</text><text context="QUESTION" xml:lang="en-US">Rp. 1.250.001 - Rp.1.750.000</text><text context="QUESTION" xml:lang="en-GB">Rp. 1.250.001 - Rp.1.750.000</text></labels><properties><property name="Value" value="4" type="8" context="Analysis"/></properties></category><category id="_3202" name="_